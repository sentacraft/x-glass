{
  "name": "x-glass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "nuke": "pkill -f 'next dev' 2>/dev/null; pkill -f 'next-server' 2>/dev/null; rm -rf .next; echo 'Cache cleared. Run npm run dev to restart.'",
    "nukedev": "npm run nuke && next dev",
    "cf:types": "wrangler types --env-interface CloudflareEnv",
    "gen:icons": "tsx scripts/gen-icons.tsx",
    "verify:icons": "tsx scripts/verify-icons.ts",
    "assets:icons": "npm run gen:icons && npm run verify:icons",
    "validate:lenses": "node --experimental-strip-types scripts/validate-lenses.mts",
    "check:static-routes": "node --experimental-strip-types scripts/check-static-routes.mts",
    "build": "npm run validate:lenses && next build && npm run check:static-routes",
    "build:cf": "npm run cf:types && npm run assets:icons && npm run build && npx opennextjs-cloudflare build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lucide-react": "^1.7.0",
    "modern-screenshot": "^4.6.8",
    "motion": "^12.38.0",
    "next": "^16.2.6",
    "next-intl": "^4.8.3",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.8",
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.1",
    "wrangler": "^4.90.0"
  }
}
