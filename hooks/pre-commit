#!/bin/sh
# Block direct edits to lenses.json.
# This file must be generated by the x-glass-pipeline materialize command.

if git diff --cached --name-only | grep -q "^src/data/lenses\.json$"; then
  echo ""
  echo "  ✗ Direct edits to src/data/lenses.json are not allowed."
  echo ""
  echo "    This file is generated by the x-glass-pipeline."
  echo "    Run 'materialize' in x-glass-pipeline, then copy the output here."
  echo ""
  echo "    To bypass (use with caution): git commit --no-verify"
  echo ""
  exit 1
fi
